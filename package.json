{
  "name": "capped-cost",
  "version": "0.3.0",
  "description": "Track monthly OpenAI and Anthropic API spend. Library, CLI, interactive setup wizard, per-model breakdown, end-of-month forecast, and Slack/Discord webhook alerts. Zero dependencies.",
  "license": "MIT",
  "author": "Kodaren1338 (https://getcapped.app)",
  "homepage": "https://getcapped.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sibbe1337/capped-cost.git"
  },
  "bugs": {
    "url": "https://github.com/Sibbe1337/capped-cost/issues"
  },
  "keywords": [
    "openai",
    "anthropic",
    "claude",
    "llm",
    "cost",
    "billing",
    "usage",
    "api",
    "tracking",
    "budget",
    "spend",
    "alert",
    "forecast",
    "slack",
    "discord",
    "cli"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "capped-cost": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js",
      "require": "./dist/webhook.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/webhook.ts src/cli.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
