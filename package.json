{
  "name": "capped-cost",
  "version": "0.4.1",
  "description": "Read monthly OpenAI and Anthropic admin spend, forecast budget burn, and drive deduped webhook alerts. Zero runtime dependencies.",
  "license": "MIT",
  "author": "Kodaren1338 (https://getcapped.app)",
  "homepage": "https://github.com/Sibbe1337/capped-cost#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sibbe1337/capped-cost.git"
  },
  "bugs": {
    "url": "https://github.com/Sibbe1337/capped-cost/issues"
  },
  "keywords": [
    "openai",
    "anthropic",
    "claude",
    "llm",
    "cost",
    "billing",
    "usage",
    "api",
    "tracking",
    "budget",
    "spend",
    "alert",
    "forecast",
    "slack",
    "discord",
    "cli"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "capped-cost": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js",
      "require": "./dist/webhook.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "SECURITY.md",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run verify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run typecheck && npm test && npm run build && npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
